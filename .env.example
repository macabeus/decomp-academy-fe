# URL of the compile/grading service the app proxies to (server-side only;
# lesson solutions never reach the browser).
#
# - Leave unset (or set to "local") to compile locally against ../sfa during
#   `next dev`.
# - In production (e.g. Amplify), set this to the deployed compile service's
#   address, for example:
#     COMPILE_API_URL=http://your-compile-service-host:8080
COMPILE_API_URL=

# --- Auth + progress (browser-safe, shipped in the bundle) ---
# AWS Cognito user pool the app authenticates against, and the API that stores
# server-side progress. The app client is public (no secret, SRP flow), so the
# pool/client IDs are safe to expose.
NEXT_PUBLIC_AWS_REGION=eu-west-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-west-1_roj6Pz3OE
NEXT_PUBLIC_COGNITO_CLIENT_ID=7fnklfk6k6c3udal7m19tgfheg
NEXT_PUBLIC_API_URL=https://api.decomp-academy.dev
