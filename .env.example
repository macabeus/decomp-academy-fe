# URL of the compile/grading service the app proxies to (server-side only;
# lesson solutions never reach the browser).
#
# - Leave unset (or set to "local") to compile locally against ../sfa during
#   `next dev`.
# - In production (e.g. Amplify), set this to the deployed compile service's
#   address, for example:
#     COMPILE_API_URL=http://your-compile-service-host:8080
COMPILE_API_URL=
